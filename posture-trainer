<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>体态训练管理</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@500;600;700;900&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --paper:#f4efe6; --paper-2:#fbf8f1; --ink:#2b2620; --ink-soft:#6b6258; --ink-faint:#9c9286;
    --clay:#c8603c; --clay-deep:#a94a2c; --clay-soft:#e8a07f; --sage:#7a8c5f; --sage-bg:#e4e9d6;
    --gold:#cf9b46; --line:#e2d9ca; --shadow:0 6px 22px -10px rgba(60,45,30,.32); --radius:18px;
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;-webkit-user-select:none;user-select:none}
  html,body{height:100%}
  body{
    background:radial-gradient(circle at 18% 0%,#efe7d6 0,transparent 55%),radial-gradient(circle at 92% 100%,#ece2cf 0,transparent 50%),#e8e0d0;
    font-family:"Noto Sans SC",sans-serif;color:var(--ink);
    display:flex;flex-direction:column;min-height:100vh;overflow:hidden;
  }
  /* 整机布局 */
  .app{flex:1;display:flex;flex-direction:column;max-width:430px;width:100%;margin:0 auto;position:relative;overflow:hidden;background:var(--paper)}
  .head{padding:max(env(safe-area-inset-top),20px) 22px 8px}
  .head .d{display:flex;align-items:baseline;gap:8px}
  .head .d b{font-family:"Noto Serif SC",serif;font-size:28px;line-height:1}
  .head .d span{font-size:12.5px;color:var(--ink-soft)}
  .head .d .wd{margin-left:auto;font-size:12.5px;color:var(--ink-soft)}
  .head .theme-tag{display:none;align-items:center;gap:7px;margin-top:11px;padding:6px 14px 6px 11px;border-radius:30px;background:var(--clay);color:#fff;font-size:13px;font-weight:500;box-shadow:var(--shadow)}
  .head .theme-tag.show{display:inline-flex}
  .head .theme-tag .dot{width:7px;height:7px;border-radius:50%;background:#fff;opacity:.85}
  .body{flex:1;position:relative;overflow:hidden}
  /* 页面切换 */
  .page{position:absolute;inset:0;display:none;flex-direction:column;overflow:hidden}
  .page.active{display:flex}
  .scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:6px 22px 20px}
  .scroll::-webkit-scrollbar{width:0}

  /* ========== Tab1 仪式打卡 ========== */
  .screen{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;padding:8px 22px 0;transition:opacity .5s ease, transform .5s cubic-bezier(.22,1,.36,1)}
  .screen.hide{opacity:0;pointer-events:none;transform:scale(.97)}
  .pre{justify-content:center}
  .pre .lead{font-family:"Noto Serif SC",serif;font-size:17px;color:var(--ink-soft);margin-bottom:4px}
  .pre .theme{font-family:"Noto Serif SC",serif;font-size:23px;font-weight:700;margin-bottom:30px;color:var(--clay-deep);text-align:center}
  .btnwrap{position:relative;width:210px;height:210px;display:grid;place-items:center}
  .ripple{position:absolute;inset:0;border-radius:50%;background:var(--clay);opacity:.13;animation:breathe 3.4s ease-in-out infinite}
  @keyframes breathe{0%,100%{transform:scale(.86);opacity:.10}50%{transform:scale(1.04);opacity:.20}}
  .prog-ring{position:absolute;inset:6px;border-radius:50%;background:conic-gradient(var(--clay) 0deg, transparent 0deg);-webkit-mask:radial-gradient(farthest-side,transparent calc(100% - 9px),#000 calc(100% - 9px));mask:radial-gradient(farthest-side,transparent calc(100% - 9px),#000 calc(100% - 9px))}
  .bigbtn{position:relative;width:184px;height:184px;border-radius:50%;background:radial-gradient(circle at 38% 32%,#d77a52,#c8603c 55%,#a94a2c);color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;box-shadow:0 18px 40px -12px rgba(169,74,44,.75),inset 0 2px 8px rgba(255,255,255,.3);cursor:pointer;transition:transform .12s ease}
  .bigbtn:active{transform:scale(.97)}
  .bigbtn.charging{transform:scale(1.04)}
  .bigbtn .ic{font-size:30px;line-height:1}
  .bigbtn .t1{font-family:"Noto Serif SC",serif;font-size:20px;font-weight:700;letter-spacing:.05em}
  .bigbtn .t2{font-size:11.5px;opacity:.9}
  .pre .hint{margin-top:26px;font-size:12.5px;color:var(--ink-faint)}
  .pre .plan{margin-top:8px;font-size:12px;color:var(--ink-soft);background:var(--paper-2);border:1px solid var(--line);padding:7px 14px;border-radius:20px}
  /* 横幅 */
  .banner{position:absolute;top:0;left:0;right:0;z-index:50;background:linear-gradient(180deg,#c8603c,#a94a2c);color:#fff;text-align:center;padding:46px 20px 26px;border-radius:0 0 26px 26px;transform:translateY(-115%);box-shadow:0 18px 30px -12px rgba(80,30,12,.6)}
  .banner.down{animation:bannerDown .7s cubic-bezier(.18,.9,.3,1.1) forwards}
  .banner.up{animation:bannerUp .55s ease-in forwards}
  @keyframes bannerDown{to{transform:translateY(0)}}
  @keyframes bannerUp{from{transform:translateY(0)}to{transform:translateY(-115%)}}
  .banner .bg{font-family:"Noto Serif SC",serif;font-size:27px;font-weight:900;letter-spacing:.08em}
  .banner .bs{font-size:13px;opacity:.92;margin-top:7px}
  .banner .ribbon{position:absolute;left:50%;bottom:-13px;transform:translateX(-50%);width:26px;height:26px;background:#a94a2c;rotate:45deg;border-radius:5px}
  /* 打卡后 */
  .post{overflow-y:auto;align-items:stretch;padding-bottom:20px}
  .post::-webkit-scrollbar{width:0}
  .cheer{font-family:"Noto Serif SC",serif;text-align:center;margin:6px 0 4px}
  .cheer .l1{font-size:15px;color:var(--ink-soft)}
  .cheer .l2{font-size:19px;font-weight:700;color:var(--clay-deep);margin-top:3px}
  .cheer .l2 em{font-style:normal;font-size:26px;color:var(--clay)}
  .fullbar{width:100%;margin:14px 0 6px}
  .fullbar .lab{display:flex;justify-content:space-between;font-size:11.5px;color:var(--ink-soft);margin-bottom:6px}
  .fullbar .track{height:10px;border-radius:6px;background:var(--line);overflow:hidden}
  .fullbar .fill{height:100%;border-radius:6px;background:linear-gradient(90deg,var(--clay-soft),var(--clay));width:0;transition:width 1s cubic-bezier(.22,1,.36,1)}
  .cal{width:100%;margin-top:12px}
  .cal .mh{display:flex;align-items:center;justify-content:center;gap:14px;font-family:"Noto Serif SC",serif;font-size:14px;color:var(--ink-soft);margin-bottom:9px}
  .cal .mh .nav{cursor:pointer;color:var(--clay);padding:2px 6px;font-size:15px}
  .cal .grid{display:grid;grid-template-columns:repeat(7,1fr);gap:6px}
  .cal .wk{text-align:center;font-size:10.5px;color:var(--ink-faint);padding-bottom:2px}
  .cell{aspect-ratio:1;border-radius:9px;display:grid;place-items:center;font-size:12px;color:var(--ink-faint);background:var(--paper-2);border:1px solid var(--line);position:relative}
  .cell.empty{background:transparent;border:none}
  .cell.done{background:radial-gradient(circle at 50% 42%,var(--clay-soft),var(--clay));color:#fff;border-color:transparent;font-weight:700;box-shadow:0 3px 8px -3px rgba(169,74,44,.6)}
  .cell.done::after{content:"";position:absolute;inset:0;border-radius:9px;border:1.5px solid rgba(255,255,255,.45);margin:3px}
  .cell.miss{border-style:dashed;border-color:var(--clay-soft);color:var(--clay-soft);cursor:pointer}
  .cell.today{outline:2px solid var(--ink);outline-offset:1px}
  .cell.stamp{animation:stamp .5s cubic-bezier(.2,1.4,.4,1)}
  @keyframes stamp{0%{transform:scale(2.2);opacity:0}60%{transform:scale(.9);opacity:1}100%{transform:scale(1)}}
  .legend{display:flex;gap:12px;justify-content:center;font-size:10.5px;color:var(--ink-soft);margin-top:10px;flex-wrap:wrap}
  .legend i{display:inline-block;width:11px;height:11px;border-radius:4px;vertical-align:-1px;margin-right:3px}
  .miles{font-size:11.5px;color:var(--clay);text-decoration:underline;margin:14px auto 0;cursor:pointer;display:block;text-align:center}
  .post-acts{display:flex;gap:10px;margin-top:14px;width:100%}
  .pbtn{flex:1;text-align:center;font-size:12.5px;padding:11px;border-radius:12px;border:1px solid var(--line);background:var(--paper-2);color:var(--ink-soft);cursor:pointer}
  .pbtn.ghost{color:var(--clay)}
  /* 基础流程（打卡后展开，可选） */
  .basics{background:linear-gradient(180deg,#eef2e2,#e7ecd7);border:1px solid #d6dec2;border-radius:16px;padding:14px 15px;margin-top:16px;width:100%}
  .basics h4{font-family:"Noto Serif SC",serif;font-size:14px;color:#5f6a45;margin-bottom:3px}
  .basics p{font-size:11.5px;color:#7d855f;margin-bottom:11px}
  .chip{display:inline-flex;align-items:center;gap:6px;font-size:12px;color:#5f6a45;background:#fff;border:1px solid #d3dcbd;padding:6px 10px;border-radius:20px;margin:0 6px 6px 0;cursor:pointer}
  .chip i{width:14px;height:14px;border-radius:5px;border:1.5px solid #aebb8c;display:inline-block;transition:.15s}
  .chip.on i{background:var(--sage);border-color:var(--sage)}
  .chip.on{color:var(--sage)}

  /* ========== Tab2 训练详情 ========== */
  .week-pick{display:flex;gap:7px;overflow-x:auto;padding:6px 2px 12px;margin:0 -2px}
  .week-pick::-webkit-scrollbar{height:0}
  .wd{flex:none;width:46px;height:56px;border-radius:13px;background:var(--paper-2);border:1px solid var(--line);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;font-size:11px;color:var(--ink-soft);cursor:pointer}
  .wd b{font-family:"Noto Serif SC",serif;font-size:15px;color:var(--ink)}
  .wd.active{background:var(--ink);border-color:var(--ink)}
  .wd.active,.wd.active b{color:var(--paper)}
  .day-title{font-family:"Noto Serif SC",serif;font-size:16px;color:var(--clay-deep);margin:6px 2px 12px}
  .ex-card{background:var(--paper-2);border:1px solid var(--line);border-radius:16px;padding:14px;margin-bottom:12px;display:flex;gap:13px;position:relative}
  .ex-ic{width:54px;height:54px;border-radius:14px;background:linear-gradient(135deg,#f0d9cb,#e8c3ad);flex:none;display:grid;place-items:center;color:var(--clay-deep)}
  .ex-ic svg{width:32px;height:32px}
  .ex-body{flex:1;min-width:0}
  .ex-nm{font-size:15px;font-weight:700}
  .ex-rep{display:inline-block;font-size:12px;color:#fff;background:var(--clay);padding:2px 9px;border-radius:20px;margin-top:6px}
  .ex-tip{font-size:12px;color:var(--ink-soft);margin-top:9px;line-height:1.5;padding-left:11px;border-left:2px solid var(--clay-soft)}
  .ex-link{display:inline-flex;align-items:center;gap:5px;font-size:12px;color:var(--clay);margin-top:9px;font-weight:500;text-decoration:none}
  .empty-day{text-align:center;color:var(--ink-faint);font-size:13px;padding:40px 0;font-family:"Noto Serif SC",serif}
  /* 编辑态行内 */
  .ex-card.edit-row{border-style:dashed;border-color:var(--clay-soft)}
  .row-acts{display:flex;flex-direction:column;gap:7px;flex:none}
  .ico-btn{width:32px;height:32px;border-radius:9px;display:grid;place-items:center;border:1px solid var(--line);background:#fff;color:var(--ink-soft);cursor:pointer}
  .ico-btn.del{color:var(--clay);border-color:#eccabd}
  .ico-btn svg{width:15px;height:15px}
  .add-row{display:flex;align-items:center;justify-content:center;gap:8px;border:1.5px dashed var(--clay-soft);color:var(--clay);border-radius:14px;padding:14px;font-size:13.5px;font-weight:500;margin-top:2px;cursor:pointer}

  /* FAB */
  .fab{position:absolute;right:18px;bottom:84px;width:54px;height:54px;border-radius:50%;background:var(--clay);color:#fff;display:grid;place-items:center;box-shadow:0 12px 24px -8px rgba(200,96,60,.7);z-index:35;cursor:pointer;transition:transform .15s}
  .fab:active{transform:scale(.92)}
  .fab svg{width:24px;height:24px}
  .fab.editing{background:var(--ink)}
  .fab.hidden{display:none}
  .edit-banner{position:absolute;left:18px;right:84px;bottom:96px;background:var(--ink);color:var(--paper);font-size:12px;padding:9px 13px;border-radius:12px;z-index:34;display:none;align-items:center;gap:8px;box-shadow:var(--shadow)}
  .edit-banner.show{display:flex}
  .edit-banner b{color:var(--clay-soft);font-weight:700}

  /* tabbar */
  .tabbar{height:calc(64px + env(safe-area-inset-bottom));padding-bottom:env(safe-area-inset-bottom);background:var(--paper-2);border-top:1px solid var(--line);display:flex;align-items:center;flex:none;z-index:40}
  .tabbar .tb{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;font-size:11px;color:var(--ink-faint);cursor:pointer;height:64px;justify-content:center}
  .tabbar .tb svg{width:22px;height:22px}
  .tabbar .tb.active{color:var(--clay)}

  .cfx{position:absolute;inset:0;z-index:55;pointer-events:none}
  .toast{position:absolute;left:50%;bottom:96px;transform:translateX(-50%) translateY(10px);background:var(--ink);color:var(--paper);font-size:12px;padding:8px 15px;border-radius:20px;opacity:0;transition:.3s;z-index:60;white-space:nowrap;pointer-events:none}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

  /* 模态 */
  .modal{position:absolute;inset:0;z-index:80;display:none;align-items:flex-end;justify-content:center;background:rgba(40,32,24,.42)}
  .modal.show{display:flex;animation:fade .2s}
  @keyframes fade{from{opacity:0}to{opacity:1}}
  .sheet{width:100%;background:var(--paper-2);border-radius:22px 22px 0 0;padding:20px 22px calc(20px + env(safe-area-inset-bottom));box-shadow:0 -10px 30px -10px rgba(40,30,20,.4);animation:slideUp .28s cubic-bezier(.22,1,.36,1)}
  @keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
  .sheet h3{font-family:"Noto Serif SC",serif;font-size:17px;margin-bottom:16px;color:#5b5247}
  .field{margin-bottom:13px}
  .field label{display:block;font-size:11.5px;color:var(--ink-soft);margin-bottom:5px}
  .field input{width:100%;border:1px solid var(--line);border-radius:11px;padding:11px 13px;font-size:14px;font-family:inherit;background:#fff;color:var(--ink);-webkit-user-select:text;user-select:text}
  .field input:focus{outline:none;border-color:var(--clay-soft)}
  .sheet-acts{display:flex;gap:10px;margin-top:8px}
  .sheet-acts button{flex:1;border:none;border-radius:12px;padding:13px;font-size:14px;font-weight:500;font-family:inherit;cursor:pointer}
  .sheet-acts .cancel{background:var(--line);color:var(--ink-soft)}
  .sheet-acts .save{background:var(--clay);color:#fff}
</style>
</head>
<body>
<div class="app">
  <div class="head">
    <div class="d"><b id="hDay">21</b><span id="hUnit">日 · 6月</span><span class="wd" id="hWd">星期日</span></div>
    <span class="theme-tag" id="hTheme"><span class="dot"></span><span id="hThemeTxt">今日主题</span></span>
  </div>

  <div class="body">
    <canvas class="cfx" id="cfx"></canvas>

    <!-- ===== Tab1 今日打卡 ===== -->
    <div class="page active" id="page1">
      <!-- 打卡前 -->
      <div class="screen pre" id="pre">
        <div class="lead">今天 · 准备好了吗</div>
        <div class="theme" id="preTheme">背部强化 B</div>
        <div class="btnwrap">
          <div class="ripple"></div>
          <div class="prog-ring" id="ring"></div>
          <div class="bigbtn" id="bigbtn">
            <span class="ic">✦</span>
            <span class="t1">长按打卡</span>
            <span class="t2">按住蓄力 1 秒</span>
          </div>
        </div>
        <div class="plan" id="prePlan">今日 3 个动作 · 约 16 分钟</div>
        <div class="miles" id="viewCal">📅 查看打卡日历</div>
        <div class="basics" id="basics"></div>
      </div>
      <!-- 横幅 -->
      <div class="banner" id="banner">
        <div class="bg">今日已完成</div>
        <div class="bs" id="bannerSub">第 1 次打卡 · 6 月又近一步</div>
        <div class="ribbon"></div>
      </div>
      <!-- 打卡后 -->
      <div class="screen post hide" id="post">
        <div class="cheer">
          <div class="l1" id="cheerL1">6 月已坚持</div>
          <div class="l2"><em id="cheerCnt">0</em> 天 · <span id="cheerTail">继续保持</span></div>
        </div>
        <div class="fullbar">
          <div class="lab"><span>满勤进度</span><span id="flab">0 / 30 天</span></div>
          <div class="track"><div class="fill" id="fill"></div></div>
        </div>
        <div class="cal">
          <div class="mh"><span class="nav" id="calPrev">◀</span><span id="calTitle">2026 年 6 月</span><span class="nav" id="calNext">▶</span></div>
          <div class="grid" id="calGrid"></div>
        </div>
        <div class="legend">
          <span><i style="background:#c8603c"></i>已打卡</span>
          <span><i style="background:#fbf8f1;border:1px solid #e2d9ca"></i>未打卡</span>
          <span><i style="border:1px dashed #e8a07f;background:transparent"></i>漏签可补</span>
        </div>
        <div class="post-acts">
          <div class="pbtn" id="backPre">返回</div>
          <div class="pbtn ghost" id="undo">↩ 撤销今日打卡</div>
        </div>
      </div>
    </div>

    <!-- ===== Tab2 训练详情 ===== -->
    <div class="page" id="page2">
      <div class="scroll">
        <div class="week-pick" id="weekPick"></div>
        <div class="day-title" id="dayTitle">周三 · 背部强化 B</div>
        <div id="exList"></div>
      </div>
    </div>

    <!-- FAB / 编辑横幅 -->
    <div class="edit-banner" id="editBanner">正在编辑 · 改动<b>实时保存</b>到本机</div>
    <div class="fab" id="fab"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg></div>

    <div class="toast" id="toast"></div>

    <!-- 编辑动作模态 -->
    <div class="modal" id="modal">
      <div class="sheet">
        <h3 id="modalTitle">新增动作</h3>
        <div class="field"><label>动作名称</label><input id="fName" placeholder="例如：弹力带面拉 Face Pull"></div>
        <div class="field"><label>次数 / 组数 / 时长</label><input id="fRep" placeholder="例如：15 次 × 4 组 · 6 min"></div>
        <div class="field"><label>动作要点</label><input id="fTip" placeholder="例如：先沉肩，肩胛贴肋滑动，不要猛夹"></div>
        <div class="field"><label>教程链接（可选）</label><input id="fLink" placeholder="https://..."></div>
        <div class="sheet-acts">
          <button class="cancel" id="mCancel">取消</button>
          <button class="save" id="mSave">保存</button>
        </div>
      </div>
    </div>
  </div>

  <div class="tabbar">
    <div class="tb active" data-tab="1"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>今日打卡</div>
    <div class="tb" data-tab="2"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h10"/></svg>训练详情</div>
  </div>
</div>

<script>
"use strict";
/* ================= 数据层（localStorage） ================= */
const LS_KEY='posture_trainer_v1';
const WD=['日','一','二','三','四','五','六']; // getDay()=0→日
const WD_FULL=['星期日','星期一','星期二','星期三','星期四','星期五','星期六'];

// 默认每周计划：键 0..6 = 周日..周六
const DEFAULT_DATA={
  version:3,
  // 每周主题（与文档一致）
  themes:{1:'背部强化 A',2:'普拉提/瑜伽',3:'背部强化 B',4:'普拉提/瑜伽',5:'背部强化 A',6:'胸椎灵活+拉伸',0:'休息'},
  // 每天动作（与文档「每周训练打卡总表」逐项对齐）
  plan:{
