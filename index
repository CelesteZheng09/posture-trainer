  .fab.hidden{display:none}
  .edit-banner{position:absolute;left:18px;right:84px;bottom:96px;background:var(--ink);color:var(--paper);font-size:12px;padding:9px 13px;border-radius:12px;z-index:34;display:none;align-items:center;gap:8px;box-shadow:var(--shadow)}
  .edit-banner.show{display:flex}
  .edit-banner b{color:var(--clay-soft);font-weight:700}

  /* tabbar */
  .tabbar{height:calc(64px + env(safe-area-inset-bottom));padding-bottom:env(safe-area-inset-bottom);background:var(--paper-2);border-top:1px solid var(--line);display:flex;align-items:center;flex:none;z-index:40}
