<style>
  :root{
    --paper:#f4efe6; --paper-2:#fbf8f1; --ink:#2b2620; --ink-soft:#6b6258; --ink-faint:#9c9286;
    --clay:#c8603c; --clay-deep:#a94a2c; --clay-soft:#e8a07f; --sage:#7a8c5f; --sage-bg:#e4e9d6;
    --gold:#cf9b46; --line:#e2d9ca; --shadow:0 6px 22px -10px rgba(60,45,30,.32); --radius:18px;
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;-webkit-user-select:none;user-select:none}
  html,body{height:100%}
  body{
    background:radial-gradient(circle at 18% 0%,#efe7d6 0,transparent 55%),radial-gradient(circle at 92% 100%,#ece2cf 0,transparent 50%),#e8e0d0;
    font-family:"Noto Sans SC",sans-serif;color:var(--ink);
    display:flex;flex-direction:column;min-height:100vh;overflow:hidden;
  }
  /* 整机布局 */
  .app{flex:1;display:flex;flex-direction:column;max-width:430px;width:100%;margin:0 auto;position:relative;overflow:hidden;background:var(--paper)}
  .head{padding:max(env(safe-area-inset-top),20px) 22px 8px}
  .head .d{display:flex;align-items:baseline;gap:8px}
  .head .d b{font-family:"Noto Serif SC",serif;font-size:28px;line-height:1}
  .head .d span{font-size:12.5px;color:var(--ink-soft)}
  .head .d .wd{margin-left:auto;font-size:12.5px;color:var(--ink-soft)}
  .head .theme-tag{display:none;align-items:center;gap:7px;margin-top:11px;padding:6px 14px 6px 11px;border-radius:30px;background:var(--clay);color:#fff;font-size:13px;font-weight:500;box-shadow:var(--shadow)}
  .head .theme-tag.show{display:inline-flex}
  .head .theme-tag .dot{width:7px;height:7px;border-radius:50%;background:#fff;opacity:.85}
  .body{flex:1;position:relative;overflow:hidden}
  /* 页面切换 */
  .page{position:absolute;inset:0;display:none;flex-direction:column;overflow:hidden}
  .page.active{display:flex}
  .scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:6px 22px 20px}
  .scroll::-webkit-scrollbar{width:0}

  /* ========== Tab1 仪式打卡 ========== */
  .screen{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;padding:8px 22px 0;transition:opacity .5s ease, transform .5s cubic-bezier(.22,1,.36,1)}
  .screen.hide{opacity:0;pointer-events:none;transform:scale(.97)}
  .pre{justify-content:center}
  .pre .lead{font-family:"Noto Serif SC",serif;font-size:17px;color:var(--ink-soft);margin-bottom:4px}
  .pre .theme{font-family:"Noto Serif SC",serif;font-size:23px;font-weight:700;margin-bottom:30px;color:var(--clay-deep);text-align:center}
  .btnwrap{position:relative;width:210px;height:210px;display:grid;place-items:center}
  .ripple{position:absolute;inset:0;border-radius:50%;background:var(--clay);opacity:.13;animation:breathe 3.4s ease-in-out infinite}
  @keyframes breathe{0%,100%{transform:scale(.86);opacity:.10}50%{transform:scale(1.04);opacity:.20}}
  .prog-ring{position:absolute;inset:6px;border-radius:50%;background:conic-gradient(var(--clay) 0deg, transparent 0deg);-webkit-mask:radial-gradient(farthest-side,transparent calc(100% - 9px),#000 calc(100% - 9px));mask:radial-gradient(farthest-side,transparent calc(100% - 9px),#000 calc(100% - 9px))}
  .bigbtn{position:relative;width:184px;height:184px;border-radius:50%;background:radial-gradient(circle at 38% 32%,#d77a52,#c8603c 55%,#a94a2c);color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;box-shadow:0 18px 40px -12px rgba(169,74,44,.75),inset 0 2px 8px rgba(255,255,255,.3);cursor:pointer;transition:transform .12s ease}
  .bigbtn:active{transform:scale(.97)}
  .bigbtn.charging{transform:scale(1.04)}
  .bigbtn .ic{font-size:30px;line-height:1}
  .bigbtn .t1{font-family:"Noto Serif SC",serif;font-size:20px;font-weight:700;letter-spacing:.05em}
  .bigbtn .t2{font-size:11.5px;opacity:.9}
  .pre .hint{margin-top:26px;font-size:12.5px;color:var(--ink-faint)}
  .pre .plan{margin-top:8px;font-size:12px;color:var(--ink-soft);background:var(--paper-2);border:1px solid var(--line);padding:7px 14px;border-radius:20px}
  /* 横幅 */
  .banner{position:absolute;top:0;left:0;right:0;z-index:50;background:linear-gradient(180deg,#c8603c,#a94a2c);color:#fff;text-align:center;padding:46px 20px 26px;border-radius:0 0 26px 26px;transform:translateY(-115%);box-shadow:0 18px 30px -12px rgba(80,30,12,.6)}
  .banner.down{animation:bannerDown .7s cubic-bezier(.18,.9,.3,1.1) forwards}
  .banner.up{animation:bannerUp .55s ease-in forwards}
  @keyframes bannerDown{to{transform:translateY(0)}}
  @keyframes bannerUp{from{transform:translateY(0)}to{transform:translateY(-115%)}}
  .banner .bg{font-family:"Noto Serif SC",serif;font-size:27px;font-weight:900;letter-spacing:.08em}
  .banner .bs{font-size:13px;opacity:.92;margin-top:7px}
  .banner .ribbon{position:absolute;left:50%;bottom:-13px;transform:translateX(-50%);width:26px;height:26px;background:#a94a2c;rotate:45deg;border-radius:5px}
  /* 打卡后 */
  .post{overflow-y:auto;align-items:stretch;padding-bottom:20px}
  .post::-webkit-scrollbar{width:0}
  .cheer{font-family:"Noto Serif SC",serif;text-align:center;margin:6px 0 4px}
  .cheer .l1{font-size:15px;color:var(--ink-soft)}
  .cheer .l2{font-size:19px;font-weight:700;color:var(--clay-deep);margin-top:3px}
  .cheer .l2 em{font-style:normal;font-size:26px;color:var(--clay)}
  .fullbar{width:100%;margin:14px 0 6px}
  .fullbar .lab{display:flex;justify-content:space-between;font-size:11.5px;color:var(--ink-soft);margin-bottom:6px}
  .fullbar .track{height:10px;border-radius:6px;background:var(--line);overflow:hidden}
  .fullbar .fill{height:100%;border-radius:6px;background:linear-gradient(90deg,var(--clay-soft),var(--clay));width:0;transition:width 1s cubic-bezier(.22,1,.36,1)}
  .cal{width:100%;margin-top:12px}
  .cal .mh{display:flex;align-items:center;justify-content:center;gap:14px;font-family:"Noto Serif SC",serif;font-size:14px;color:var(--ink-soft);margin-bottom:9px}
  .cal .mh .nav{cursor:pointer;color:var(--clay);padding:2px 6px;font-size:15px}
  .cal .grid{display:grid;grid-template-columns:repeat(7,1fr);gap:6px}
  .cal .wk{text-align:center;font-size:10.5px;color:var(--ink-faint);padding-bottom:2px}
