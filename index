  /* FAB */
  .fab{position:absolute;right:18px;bottom:84px;width:54px;height:54px;border-radius:50%;background:var(--clay);color:#fff;display:grid;place-items:center;box-shadow:0 12px 24px -8px rgba(200,96,60,.7);z-index:35;cursor:pointer;transition:transform .15s}
  .fab:active{transform:scale(.92)}
