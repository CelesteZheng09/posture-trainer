function dkey(y,m,d){return y+'-'+m+'-'+d;} // m: 1-12
function todayKey(){return dkey(NOW.getFullYear(),NOW.getMonth()+1,NOW.getDate());}
function weekdayOf(y,m,d){return new Date(y,m-1,d).getDay();}
function daysInMonth(y,m){return new Date(y,m,0).getDate();}

/* ================= 顶部日期 ================= */
function renderHead(){
  document.getElementById('hDay').textContent=NOW.getDate();
  document.getElementById('hUnit').textContent='日 · '+(NOW.getMonth()+1)+'月';
  document.getElementById('hWd').textContent=WD_FULL[NOW.getDay()];
}

