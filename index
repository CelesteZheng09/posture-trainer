function iconFor(name){
  const n=name||'';
  if(/YTWL|YTW|YWT/i.test(n))return ICONS.ytwl;
  if(/面拉|扩胸|Pull-?apart|pull apart/i.test(n))return ICONS.pull;
  if(/高位下拉|下拉/.test(n))return ICONS.pulldown;
  if(/飞鸟/.test(n))return ICONS.fly;
  if(/划船|row/i.test(n))return ICONS.row;
  if(/泡沫轴/.test(n))return ICONS.roller;
  if(/猫牛|鸟狗|贝壳/.test(n))return ICONS.cat;
  if(/拉伸|婴儿式|stretch/i.test(n))return ICONS.stretch;
  if(/普拉提|瑜伽|核心|yoga|pilates/i.test(n))return ICONS.yoga;
  if(/休息|散步|walk/i.test(n))return ICONS.walk;
  if(/基础流程|靠墙|收下巴|门框/.test(n))return ICONS.wall;
  return ICONS.star;
}

/* ================= 编辑模态 ================= */
const modal=document.getElementById('modal');
function openModal(day,idx){
  editTarget={day,idx};
  const isNew=idx===null;
  document.getElementById('modalTitle').textContent=isNew?'新增动作':'编辑动作';
  const a=isNew?{name:'',rep:'',tip:'',link:''}:DATA.plan[day][idx];
  document.getElementById('fName').value=a.name||'';
  document.getElementById('fRep').value=a.rep||'';
  document.getElementById('fTip').value=a.tip||'';
  document.getElementById('fLink').value=a.link||'';
  modal.classList.add('show');
}
document.getElementById('mCancel').onclick=()=>modal.classList.remove('show');
modal.onclick=(e)=>{if(e.target===modal)modal.classList.remove('show');};
document.getElementById('mSave').onclick=()=>{
  const name=document.getElementById('fName').value.trim();
  if(!name){toast('请填写动作名称');return;}
  const {day,idx}=editTarget;
  const prev=(idx!==null && DATA.plan[day] && DATA.plan[day][idx])?DATA.plan[day][idx]:null;
  const obj={name,rep:document.getElementById('fRep').value.trim(),tip:document.getElementById('fTip').value.trim(),link:document.getElementById('fLink').value.trim(),linkText:(prev&&prev.linkText)?prev.linkText:'查看教程'};
  if(!DATA.plan[day])DATA.plan[day]=[];
  if(idx===null)DATA.plan[day].push(obj);else DATA.plan[day][idx]=obj;
  save();modal.classList.remove('show');renderExList();toast(idx===null?'已新增动作':'已保存修改');
};

/* ================= Tab 切换 & FAB ================= */
function switchTab(t){
  curTab=t;
  document.querySelectorAll('.tabbar .tb').forEach(tb=>tb.classList.toggle('active',+tb.dataset.tab===t));
  document.getElementById('page1').classList.toggle('active',t===1);
  document.getElementById('page2').classList.toggle('active',t===2);
  // 头部主题标签只在 Tab1 打卡前阶段隐藏，统一不显示；编辑态只对 Tab2 有意义
  if(t===1){
    // 退出编辑态
    if(editMode)toggleEdit(false);
    document.getElementById('fab').classList.add('hidden'); // Tab1 无需编辑入口
    // 进入 Tab1：根据是否已打卡决定显示哪屏
    if(isChecked(todayKey()))showPost(false);else showPre();
  }else{
    document.getElementById('fab').classList.remove('hidden');
    renderWeekPick();renderExList();
  }
}
document.querySelectorAll('.tabbar .tb').forEach(tb=>tb.onclick=()=>switchTab(+tb.dataset.tab));

function toggleEdit(force){
  editMode=(typeof force==='boolean')?force:!editMode;
  const fab=document.getElementById('fab');
  fab.classList.toggle('editing',editMode);
  fab.innerHTML=editMode
    ?'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12l5 5L20 6"/></svg>'
    :'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>';
  document.getElementById('editBanner').classList.toggle('show',editMode);
  renderExList();
  if(!editMode)toast('已退出编辑');
}
document.getElementById('fab').onclick=()=>{if(curTab===2)toggleEdit();};

/* ================= toast ================= */
let toastH=null;
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(toastH);toastH=setTimeout(()=>t.classList.remove('show'),1600);}

/* ================= 初始化 ================= */
renderHead();
renderPre();
switchTab(1);
</script>
