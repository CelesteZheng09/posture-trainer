let editMode=false;
let selDay=NOW.getDay();      // Tab2 选中的星期
let calY=NOW.getFullYear(), calM=NOW.getMonth()+1; // 月历显示的年月
let editTarget={day:null,idx:null}; // 编辑/新增的目标

/* ================= Tab1 仪式打卡 ================= */
const elPre=document.getElementById('pre'), elPost=document.getElementById('post'),
      elBanner=document.getElementById('banner'), elRing=document.getElementById('ring'),
      elBtn=document.getElementById('bigbtn'), elCfx=document.getElementById('cfx');

function isChecked(key){return DATA.checkins[key] && DATA.checkins[key].checked;}

function renderPre(){
  const th=DATA.themes[NOW.getDay()]||'今日训练';
  document.getElementById('preTheme').textContent=th;
  const acts=DATA.plan[NOW.getDay()]||[];
  let mins=0;acts.forEach(a=>{const m=(a.rep||'').match(/(\d+)\s*min/);if(m)mins+=parseInt(m[1]);});
  document.getElementById('prePlan').textContent='今日 '+acts.length+' 个动作'+(mins?(' · 约 '+mins+' 分钟'):'');
  renderBasics();
}

function monthDoneCount(y,m){
  let n=0;for(let d=1;d<=daysInMonth(y,m);d++){if(isChecked(dkey(y,m,d)))n++;}return n;
}
function renderPost(stampToday){
  const mDone=monthDoneCount(NOW.getFullYear(),NOW.getMonth()+1);
  document.getElementById('cheerL1').textContent=(NOW.getMonth()+1)+' 月已坚持';
  document.getElementById('cheerCnt').textContent=mDone;
  const total=daysInMonth(NOW.getFullYear(),NOW.getMonth()+1);
  const left=total-mDone;
  document.getElementById('cheerTail').textContent=left>0?('再 '+left+' 天满勤'):'本月满勤达成 🎉';
  renderCal(stampToday);
}
function renderCal(stampToday){
  document.getElementById('calTitle').textContent=calY+' 年 '+calM+' 月';
  const grid=document.getElementById('calGrid');grid.innerHTML='';
  ['一','二','三','四','五','六','日'].forEach(w=>{const e=document.createElement('div');e.className='wk';e.textContent=w;grid.appendChild(e);});
  // 周一为首列：getDay 0(日)→6, 1(一)→0
  const firstW=(weekdayOf(calY,calM,1)+6)%7;
  for(let i=0;i<firstW;i++){const e=document.createElement('div');e.className='cell empty';grid.appendChild(e);}
  const dim=daysInMonth(calY,calM);
  const isCurMonth=(calY===NOW.getFullYear() && calM===NOW.getMonth()+1);
  for(let d=1;d<=dim;d++){
    const e=document.createElement('div');e.className='cell';
    const key=dkey(calY,calM,d);
    const isToday=isCurMonth && d===NOW.getDate();
    const past=(new Date(calY,calM-1,d) < new Date(NOW.getFullYear(),NOW.getMonth(),NOW.getDate()));
    if(isChecked(key)){
      e.classList.add('done');e.textContent=d;
      if(isToday && stampToday)e.classList.add('stamp');
      e.title='已打卡 · 点击取消';
      e.onclick=()=>{cancelCheckin(key,d);};
    } else if(past){
      // 过去未打卡 = 漏签可补
      e.classList.add('miss');e.textContent=d;e.title='漏签 · 点击补卡';
      e.onclick=()=>{makeup(key,d);};
    } else {
      e.textContent=d;
    }
    if(isToday)e.classList.add('today');
    grid.appendChild(e);
  }
  // 满勤进度（始终基于当前真实月份）
  const mDone=monthDoneCount(NOW.getFullYear(),NOW.getMonth()+1);
  const total=daysInMonth(NOW.getFullYear(),NOW.getMonth()+1);
  document.getElementById('flab').textContent=mDone+' / '+total+' 天';
  const fill=document.getElementById('fill');
  requestAnimationFrame(()=>{fill.style.width=(mDone/total*100)+'%';});
}
function makeup(key,d){
  DATA.checkins[key]={checked:true,basics:DATA.checkins[key]?DATA.checkins[key].basics:[]};save();
  toast('已补卡 '+d+' 日');renderPost(false);
}
function cancelCheckin(key,d){
  if(DATA.checkins[key])DATA.checkins[key].checked=false;save();
  toast('已取消 '+d+' 日打卡');
  // 若取消的是今天，回到打卡前界面；否则仅刷新日历
  if(key===todayKey()){showPre();}
  else{renderPost(false);}
}
function renderBasics(){
  const key=todayKey();
  const st=DATA.checkins[key]&&DATA.checkins[key].basics?DATA.checkins[key].basics:[];
  const wrap=document.getElementById('basics');
  let h='<h4>5 分钟基础流程</h4><p>无论今天练什么，这 6 项都要完成</p>';
  DATA.dailyBasics.forEach((b,i)=>{h+='<span class="chip'+(st[i]?' on':'')+'" data-bi="'+i+'"><i></i>'+b+'</span>';});
  wrap.innerHTML=h;
  wrap.querySelectorAll('.chip').forEach(c=>{
    c.onclick=()=>{
      const i=+c.dataset.bi;
      if(!DATA.checkins[key])DATA.checkins[key]={checked:false,basics:[]};
      if(!DATA.checkins[key].basics)DATA.checkins[key].basics=[];
      DATA.checkins[key].basics[i]=!DATA.checkins[key].basics[i];save();
      c.classList.toggle('on');
    };
  });
}

// 切换到已打卡视图
function showPost(stamp){
  elPre.classList.add('hide');elPost.classList.remove('hide');
  calY=NOW.getFullYear();calM=NOW.getMonth()+1;
  renderPost(stamp);
  if(typeof clampNav==='function')clampNav();
  // 撤销按钮只在今天已打卡时显示
  document.getElementById('undo').style.display = isChecked(todayKey())?'block':'none';
}
function showPre(){
  elPost.classList.add('hide');elPre.classList.remove('hide');setRing(0);
  elBanner.classList.remove('down','up');elBanner.style.transform='';
}

/* 长按蓄力 */
let raf=null,startT=0,charging=false;const DUR=1000;
function setRing(p){elRing.style.background='conic-gradient(var(--clay) '+(p*360)+'deg, transparent '+(p*360)+'deg)';}
function tick(t){
  if(!startT)startT=t;
  const p=Math.min((t-startT)/DUR,1);
  setRing(p);
  if(p>=1){finish();return;}
  raf=requestAnimationFrame(tick);
}
function begin(e){e.preventDefault();if(charging)return;charging=true;startT=0;elBtn.classList.add('charging');raf=requestAnimationFrame(tick);}
function cancelCharge(){
  if(!charging)return;charging=false;elBtn.classList.remove('charging');cancelAnimationFrame(raf);
  let m=(elRing.style.background.match(/(\d+\.?\d*)deg/)||[])[1]||0;let p=parseFloat(m)/360;
  const t0=performance.now();const dur=260;
  (function back(t){const k=Math.min((t-t0)/dur,1);setRing(p*(1-k));if(k<1)requestAnimationFrame(back);})(t0);
}
function finish(){
  charging=false;elBtn.classList.remove('charging');setRing(1);
  if(navigator.vibrate)navigator.vibrate([20,40,30]);
  // 写入打卡
  const key=todayKey();
  DATA.checkins[key]={checked:true,basics:DATA.checkins[key]?DATA.checkins[key].basics:[]};save();
  confetti(false);
  // 横幅次数
  const mDone=monthDoneCount(NOW.getFullYear(),NOW.getMonth()+1);
  document.getElementById('bannerSub').textContent='第 '+mDone+' 次打卡 · '+(NOW.getMonth()+1)+' 月又近一步';
  elBanner.classList.remove('up');elBanner.classList.add('down');
  setTimeout(()=>{
    elBanner.classList.remove('down');elBanner.classList.add('up');
    showPost(true);
  },1500);
}
elBtn.addEventListener('pointerdown',begin);
elBtn.addEventListener('pointerup',cancelCharge);
elBtn.addEventListener('pointerleave',cancelCharge);
elBtn.addEventListener('pointercancel',cancelCharge);

document.getElementById('undo').onclick=()=>{
  const key=todayKey();
  if(DATA.checkins[key])DATA.checkins[key].checked=false;save();
  showPre();toast('已撤销今日打卡');
};
// 从打卡前进入日历查看
document.getElementById('viewCal').onclick=()=>{showPost(false);};
// 从日历返回
document.getElementById('backPre').onclick=()=>{showPre();};
// 月历翻页：起点 2026 年 6 月，终点当前真实月份
const MIN_Y=2026, MIN_M=6;
function ym(y,m){return y*12+m;}
function clampNav(){
  const prev=document.getElementById('calPrev'), next=document.getElementById('calNext');
  const cur=ym(calY,calM), min=ym(MIN_Y,MIN_M), max=ym(NOW.getFullYear(),NOW.getMonth()+1);
  prev.style.visibility = cur<=min ? 'hidden' : 'visible';
  next.style.visibility = cur>=max ? 'hidden' : 'visible';
}
document.getElementById('calPrev').onclick=()=>{
  if(ym(calY,calM)<=ym(MIN_Y,MIN_M))return;
  calM--;if(calM<1){calM=12;calY--;}renderCal(false);clampNav();
};
document.getElementById('calNext').onclick=()=>{
  if(ym(calY,calM)>=ym(NOW.getFullYear(),NOW.getMonth()+1))return;
  calM++;if(calM>12){calM=1;calY++;}renderCal(false);clampNav();
};

/* 彩花 */
function confetti(grand){
  const dpr=window.devicePixelRatio||1;const w=elCfx.clientWidth,h=elCfx.clientHeight;
  elCfx.width=w*dpr;elCfx.height=h*dpr;const ctx=elCfx.getContext('2d');ctx.scale(dpr,dpr);
  const cols=['#c8603c','#e8a07f','#7a8c5f','#cf9b46','#a94a2c','#e9c46a'];
  const N=grand?160:90;const ps=[];
  for(let i=0;i<N;i++){ps.push({x:w/2+(Math.random()-.5)*40,y:h*0.42,vx:(Math.random()-.5)*(grand?13:9),vy:(Math.random()*-1-(grand?7:5)),g:.22+Math.random()*.12,s:4+Math.random()*5,rot:Math.random()*6,vr:(Math.random()-.5)*.4,c:cols[i%cols.length],life:0,max:90+Math.random()*40,shape:Math.random()<.5});}
  let frame=0;
  function draw(){ctx.clearRect(0,0,w,h);let alive=false;
    ps.forEach(p=>{if(p.life>p.max)return;alive=true;p.life++;p.vy+=p.g;p.x+=p.vx;p.y+=p.vy;p.rot+=p.vr;
      const a=Math.max(0,1-p.life/p.max);ctx.globalAlpha=a;ctx.fillStyle=p.c;ctx.save();ctx.translate(p.x,p.y);ctx.rotate(p.rot);
      if(p.shape)ctx.fillRect(-p.s/2,-p.s/2,p.s,p.s*1.6);else{ctx.beginPath();ctx.ellipse(0,0,p.s/2,p.s/1.4,0,0,7);ctx.fill();}
      ctx.restore();});
    ctx.globalAlpha=1;frame++;
    if(alive&&frame<200)requestAnimationFrame(draw);else ctx.clearRect(0,0,w,h);
  }
  draw();
}

/* ================= Tab2 训练详情 ================= */
function renderWeekPick(){
  const wp=document.getElementById('weekPick');wp.innerHTML='';
  // 周一到周日顺序
  const order=[1,2,3,4,5,6,0];
  order.forEach(dy=>{
    const e=document.createElement('div');e.className='wd'+(dy===selDay?' active':'');
    const th=DATA.themes[dy]||'';
    const short=th.length>3?th.slice(0,2):th;
    e.innerHTML='<b>'+WD[dy]+'</b>'+short;
    e.onclick=()=>{selDay=dy;renderWeekPick();renderExList();};
    wp.appendChild(e);
  });
}
function renderExList(){
  document.getElementById('dayTitle').textContent='周'+WD[selDay]+' · '+(DATA.themes[selDay]||'');
  const list=document.getElementById('exList');list.innerHTML='';
  const acts=DATA.plan[selDay]||[];
  if(acts.length===0 && !editMode){
    list.innerHTML='<div class="empty-day">今天没有安排动作</div>';
  }
  acts.forEach((a,idx)=>{
    const card=document.createElement('div');
    card.className='ex-card'+(editMode?' edit-row':'');
    const linkTxt=a.linkText?a.linkText:'查看教程';
    let inner='<div class="ex-ic">'+iconFor(a.name)+'</div><div class="ex-body">'+
      '<div class="ex-nm">'+esc(a.name)+'</div>'+
      (a.rep?'<span class="ex-rep">'+esc(a.rep)+'</span>':'')+
      (a.tip?'<div class="ex-tip">'+esc(a.tip)+'</div>':'')+
      (a.link?'<a class="ex-link" href="'+esc(a.link)+'" target="_blank" rel="noopener" data-link="'+esc(a.link)+'">▶ '+esc(linkTxt)+'</a>':(a.linkText?'<div class="ex-link" style="color:var(--ink-faint)">'+esc(a.linkText)+'</div>':''))+
      '</div>';
    if(editMode){
      inner+='<div class="row-acts">'+
        '<div class="ico-btn" data-edit="'+idx+'"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg></div>'+
        '<div class="ico-btn del" data-del="'+idx+'"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg></div>'+
        '</div>';
    }
    card.innerHTML=inner;
    list.appendChild(card);
  });
  // 教程链接点击：优先新窗口打开；沙箱/预览中被拦截时降级为复制链接
  list.querySelectorAll('a[data-link]').forEach(el=>{
    el.addEventListener('click',ev=>{
      ev.preventDefault();
      const url=el.getAttribute('data-link');
      if(!url)return;
      let win=null;
      try{win=window.open(url,'_blank','noopener');}catch(e){win=null;}
      if(win){return;} // 成功打开
      // 被拦截：尝试复制到剪贴板并提示
      const done=()=>toast('链接已复制，请粘贴到浏览器打开');
      const fail=()=>toast('请长按链接手动复制：'+url);
      try{
        if(navigator.clipboard&&navigator.clipboard.writeText){
          navigator.clipboard.writeText(url).then(done).catch(()=>{legacyCopy(url)?done():fail();});
        }else{ legacyCopy(url)?done():fail(); }
      }catch(e){ legacyCopy(url)?done():fail(); }
    });
  });
  if(editMode){
    const add=document.createElement('div');add.className='add-row';add.textContent='＋ 新增动作';
    add.onclick=()=>openModal(selDay,null);
    list.appendChild(add);
    list.querySelectorAll('[data-edit]').forEach(b=>b.onclick=()=>openModal(selDay,+b.dataset.edit));
    list.querySelectorAll('[data-del]').forEach(b=>b.onclick=()=>{
      DATA.plan[selDay].splice(+b.dataset.del,1);save();renderExList();toast('已删除动作');
    });
  }
}
function esc(s){return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function legacyCopy(text){try{const ta=document.createElement('textarea');ta.value=text;ta.style.position='fixed';ta.style.opacity='0';document.body.appendChild(ta);ta.focus();ta.select();const ok=document.execCommand('copy');document.body.removeChild(ta);return ok;}catch(e){return false;}}

