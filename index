function load(){
  try{const s=localStorage.getItem(LS_KEY);if(s)return JSON.parse(s);}catch(e){}
  return JSON.parse(JSON.stringify(DEFAULT_DATA));
}
let STORAGE_OK=true;
function save(){try{localStorage.setItem(LS_KEY,JSON.stringify(DATA));}catch(e){STORAGE_OK=false;/* opaque-origin/sandbox: 降级为内存态，不中断流程 */}}
let DATA=load();
// 兼容旧结构补全
['themes','plan','dailyBasics','checkins'].forEach(k=>{if(!DATA[k])DATA[k]=JSON.parse(JSON.stringify(DEFAULT_DATA[k]));});
// 版本迁移：旧版计划内容用新版覆盖，但保留用户的打卡记录
if((DATA.version||1) < DEFAULT_DATA.version){
  const keep=DATA.checkins;
  DATA=JSON.parse(JSON.stringify(DEFAULT_DATA));
  DATA.checkins=keep||{};
  save();
}

