  .cfx{position:absolute;inset:0;z-index:55;pointer-events:none}
  .toast{position:absolute;left:50%;bottom:96px;transform:translateX(-50%) translateY(10px);background:var(--ink);color:var(--paper);font-size:12px;padding:8px 15px;border-radius:20px;opacity:0;transition:.3s;z-index:60;white-space:nowrap;pointer-events:none}
